{
  "name": "@ori-rando/shared",
  "version": "1.0.0",
  "description": "Shared assets for launcher and web",
  "author": {
    "name": "Timo Schwarzer",
    "email": "timo@schwarzer.dev"
  },
  "scripts": {
    "protoc:win": "cd proto && protoc --plugin=../../node_modules/.bin/protoc-gen-ts_proto.cmd --ts_proto_out=. --ts_proto_opt=esModuleInterop=true --ts_proto_opt=outputTypeRegistry=true --ts_proto_opt=useNullAsOptional=true --ts_proto_opt=outputPartialMethods=false messages.proto",
    "protoc:linux": "cd proto && protoc --plugin=../../node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=. --ts_proto_opt=esModuleInterop=true --ts_proto_opt=outputTypeRegistry=true --ts_proto_opt=useNullAsOptional=true --ts_proto_opt=outputPartialMethods=false messages.proto",
    "openapi:seedgen": "openapi-typescript --root-types --root-types-no-schema-prefix"
  },
  "license": "MIT",
  "dependencies": {
    "klona": "^2.0.6",
    "protobufjs": "^7.5.4",
    "ts-proto": "^2.11.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1"
  }
}
